<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="examen1prograII.Views.ListaPage"
    Title="Lista de Sitios">

    <CollectionView x:Name="listaSitios">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Frame
                    Margin="10"
                    Padding="10"
                    BorderColor="#455A64">

                    <VerticalStackLayout Spacing="8">

                        <Image
                            Source="{Binding Imagen}"
                            HeightRequest="180"
                            Aspect="AspectFill"/>

                        <Label
                            Text="{Binding Descripcion}"
                            FontSize="18"
                            FontAttributes="Bold"/>

                        <Label
                            Text="{Binding Latitud}"/>

                        <Label
                            Text="{Binding Longitud}"/>

                        <Button
                            Text="Ver Mapa"
                            BackgroundColor="#0D47A1"
                            TextColor="White"
                            CommandParameter="{Binding .}"
                            Clicked="VerMapa"/>

                        <Button
                            Text="Editar"
                            BackgroundColor="#0D47A1"
                            TextColor="White"
                            CommandParameter="{Binding .}"
                            Clicked="EditarSitio"/>

                        <Button
                            Text="Eliminar Casa"
                            BackgroundColor="#C62828"
                            TextColor="White"
                            CommandParameter="{Binding .}"
                            Clicked="EliminarSitio"/>

                    </VerticalStackLayout>

                </Frame>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>