<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="examen1prograII.Views.SitioMapaPage"
             Title="Detalle del Sitio">

    <Grid Padding="20" RowDefinitions="*, Auto" BackgroundColor="#F5F5F5">
        <StackLayout Grid.Row="0" VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <Label Text="" FontSize="60" HorizontalOptions="Center"/>
            <Label Text="Abriendo Ubicación en Google Maps..." FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#0D47A1"/>

            <Frame CornerRadius="10" Padding="15" BackgroundColor="White" HasShadow="True">
                <StackLayout>
                    <Label x:Name="lblDesc" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Label x:Name="lblCoords" FontSize="14" TextColor="Gray" HorizontalOptions="Center" Margin="0,5,0,0"/>
                </StackLayout>
            </Frame>
        </StackLayout>

        <Button Grid.Row="1" 
                Text="Compartir Imagen del Sitio" 
                Clicked="OnCompartirClicked"
                HeightRequest="50"
                BackgroundColor="#0D47A1"
                TextColor="Black"
                FontAttributes="Bold"
                CornerRadius="25"/>
    </Grid>
</ContentPage>